{
  "name": "hh-job-assistant",
  "version": "0.1.198",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:summary": "bash scripts/test-summary.sh",
    "build": "npm test",
    "test:extension": "node scripts/chromium-extension-smoke.mjs",
    "test:hh:chromium": "node scripts/chromium-hh-live-smoke.mjs",
    "test:hh": "node scripts/hh-live-smoke.mjs",
    "configure:hh:chromium": "node scripts/chromium-configure-extension.mjs",
    "sync:hh:auth": "node scripts/sync-hh-auth-to-chromium.mjs",
    "run:hh:chromium": "node scripts/chromium-run-action.mjs",
    "start:hh:chromium": "node scripts/chromium-start-auto-apply.mjs",
    "inspect:logs": "node scripts/inspect-extension-log.mjs",
    "diff:summary": "bash scripts/diff-summary.sh",
    "context:budget": "bash scripts/context-budget.sh",
    "test:all": "npm test && npm run test:extension && npm run test:hh"
  }
}
